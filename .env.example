# Apple signing/notarization — copy to .env.local and fill in values
# NEVER commit .env.local to the repo

# Developer ID Application certificate name (from Keychain)
APPLE_IDENTITY=

# Apple ID used for notarization
APPLE_ID=

# App-specific password generated at appleid.apple.com
APPLE_APP_SPECIFIC_PASSWORD=

# Apple Developer Team ID
APPLE_TEAM_ID=
