{
  "name": "whispro",
  "productName": "WhispPro",
  "version": "0.1.0",
  "description": "Local voice transcription desktop app",
  "author": "",
  "main": "dist/main/index.js",
  "scripts": {
    "dev": "concurrently \"tsc -p tsconfig.main.json --watch\" \"vite --config app/renderer/vite.config.ts\" \"wait-on http://localhost:3000 && electron .\"",
    "dev:renderer": "vite --config app/renderer/vite.config.ts",
    "build": "tsc -p tsconfig.main.json && vite build --config app/renderer/vite.config.ts",
    "package": "npm run build && electron-forge package",
    "make": "npm run build && electron-forge make",
    "icons": "bash scripts/generate-icons.sh",
    "test": "jest",
    "lint": "eslint 'app/**/*.{ts,tsx}' 'modules/**/*.ts'"
  },
  "keywords": [
    "electron",
    "whisper",
    "transcription",
    "voice"
  ],
  "license": "MIT",
  "devDependencies": {
    "@electron-forge/cli": "^7.0.0",
    "@electron-forge/maker-dmg": "^7.0.0",
    "@electron-forge/shared-types": "^7.11.1",
    "@testing-library/jest-dom": "^6.0.0",
    "@testing-library/react": "^14.0.0",
    "@testing-library/user-event": "^14.0.0",
    "@types/better-sqlite3": "^7.6.0",
    "@types/jest": "^29.0.0",
    "@types/node": "^20.0.0",
    "@types/react": "^18.0.0",
    "@types/react-dom": "^18.0.0",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "@vitejs/plugin-react": "^4.0.0",
    "concurrently": "^8.0.0",
    "electron": "^28.0.0",
    "eslint": "^8.0.0",
    "jest": "^29.0.0",
    "jest-environment-jsdom": "^29.0.0",
    "ts-jest": "^29.0.0",
    "typescript": "^5.0.0",
    "vite": "^5.0.0",
    "wait-on": "^7.0.0"
  },
  "dependencies": {
    "better-sqlite3": "^12.9.0",
    "react": "^18.0.0",
    "react-dom": "^18.0.0"
  }
}
